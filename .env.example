# Vercel Deployment Required Environment Variables

# The URL of your Supabase project (e.g., https://xxxxxxxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# (Optional) Anon key for client-side queries, not strictly required for current actions
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# The Service Role Key to bypass RLS for server-side form submissions (NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Password for the /admin dashboard to view messages and subscribers
ADMIN_PASSWORD=
